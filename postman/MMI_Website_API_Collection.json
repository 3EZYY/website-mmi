              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mmi.test\",\n  \"password\": \"password\",\n  \"remember\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            }
