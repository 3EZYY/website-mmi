      ]
    },
    {
      "name": "💳 Midtrans Direct API",
      "description": "Direct Midtrans API calls for testing (bypass Laravel)",
      "item": [
        {
          "name": "Create Snap Token",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{midtrans_server_key}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction_details\": {\n    \"order_id\": \"TEST-ORDER-001\",\n    \"gross_amount\": 50000\n  },\n  \"customer_details\": {\n    \"first_name\": \"Budi\",\n    \"last_name\": \"Test\",\n    \"email\": \"budi@example.com\",\n    \"phone\": \"081234567890\"\n  },\n  \"item_details\": [\n    {\n      \"id\": \"ITEM-001\",\n      \"price\": 25000,\n      \"quantity\": 2,\n      \"name\": \"Test Souvenir\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://app.sandbox.midtrans.com/snap/v1/transactions",
              "protocol": "https",
              "host": ["app", "sandbox", "midtrans", "com"],
              "path": ["snap", "v1", "transactions"]
            },
            "description": "## Create Snap Token directly from Midtrans\n\nSet your Server Key in the collection variable `midtrans_server_key`.\n\n### Response Example\n```json\n{\n  \"token\": \"66e4fa55-fdac-4ef9-91b5-733b97d1b862\",\n  \"redirect_url\": \"https://app.sandbox.midtrans.com/snap/v2/vtweb/66e4fa55...\"\n}\n```"
          }
        },
        {
          "name": "Check Transaction Status",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{midtrans_server_key}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "https://api.sandbox.midtrans.com/v2/:order_id/status",
              "protocol": "https",
              "host": ["api", "sandbox", "midtrans", "com"],
              "path": ["v2", ":order_id", "status"],
              "variable": [
                {
                  "key": "order_id",
                  "value": "TEST-ORDER-001",
                  "description": "Order ID from previous transaction"
                }
              ]
            }
          }
        },
        {
          "name": "Simulate Webhook Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction_time\": \"2024-12-18 13:00:00\",\n  \"transaction_status\": \"settlement\",\n  \"transaction_id\": \"midtrans-txn-id-123\",\n  \"status_message\": \"midtrans payment notification\",\n  \"status_code\": \"200\",\n  \"signature_key\": \"generate-using-sha512\",\n  \"payment_type\": \"qris\",\n  \"order_id\": \"TICKET-uuid-here\",\n  \"merchant_id\": \"your-merchant-id\",\n  \"gross_amount\": \"50000.00\",\n  \"fraud_status\": \"accept\",\n  \"currency\": \"IDR\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/midtrans/callback",
              "host": ["{{base_url}}"],
              "path": ["midtrans", "callback"]
            },
            "description": "## Midtrans Webhook Simulation\n\n**Note**: You need to create this route in your Laravel app if it doesn't exist.\n\n### Signature Key Generation\nThe signature_key is calculated as:\n```\nSHA512(order_id + status_code + gross_amount + ServerKey)\n```\n\n### Transaction Status Values\n- `capture` - Card payment captured\n- `settlement` - Transaction settled\n- `pending` - Waiting for payment\n- `deny` - Payment denied\n- `cancel` - Transaction cancelled\n- `expire` - Transaction expired\n- `refund` - Transaction refunded"
          }
        }
      ]
    },
