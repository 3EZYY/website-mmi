    {
      "name": "🎫 Ticket Transactions",
      "description": "Ticket booking endpoints",
      "item": [
        {
          "name": "Submit Ticket Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-XSRF-TOKEN",
                "value": "{{xsrf_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visitor_name\": \"Budi Santoso\",\n  \"email\": \"budi@example.com\",\n  \"phone\": \"081234567890\",\n  \"visit_date\": \"2024-12-25\",\n  \"quantity\": 2,\n  \"total_price\": 10000\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tickets",
              "host": ["{{base_url}}"],
              "path": ["tickets"]
            },
            "description": "## Validation Rules\n- `visitor_name`: required, string, min:3, max:255\n- `email`: required, valid email, max:255\n- `phone`: required, string, min:10, max:20\n- `visit_date`: required, date, must be today or future\n- `quantity`: required, integer, min:1, max:50\n- `total_price`: required, numeric, min:0\n\n## Note\nRequires authentication. Response includes Midtrans snap_token for payment."
          }
        },
        {
          "name": "Delete Ticket (Auth Required)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-XSRF-TOKEN",
                "value": "{{xsrf_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tickets/:ticket",
              "host": ["{{base_url}}"],
              "path": ["tickets", ":ticket"],
              "variable": [
                {
                  "key": "ticket",
                  "value": "ticket-uuid-here",
                  "description": "Ticket UUID (must be pending status)"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🛒 Souvenir Checkout",
      "description": "Souvenir order endpoints",
      "item": [
        {
          "name": "Get Checkout Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/checkout?cart[souvenir-uuid-1]=2&cart[souvenir-uuid-2]=1",
              "host": ["{{base_url}}"],
              "path": ["checkout"],
              "query": [
                {
                  "key": "cart[souvenir-uuid-1]",
                  "value": "2",
                  "description": "Souvenir ID => Quantity"
                },
                {
                  "key": "cart[souvenir-uuid-2]",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Submit Souvenir Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-XSRF-TOKEN",
                "value": "{{xsrf_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"081234567890\",\n  \"shipping_address\": \"Budi Santoso, Jl. Malang No. 123, Malang, Jawa Timur 65111\",\n  \"payment_method\": \"qris\",\n  \"total_amount\": 150000,\n  \"order_items\": [\n    {\n      \"souvenir_id\": \"souvenir-uuid-here\",\n      \"quantity\": 2,\n      \"price\": 50000\n    },\n    {\n      \"souvenir_id\": \"another-souvenir-uuid\",\n      \"quantity\": 1,\n      \"price\": 50000\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/checkout",
              "host": ["{{base_url}}"],
              "path": ["checkout"]
            },
            "description": "## Validation Rules\n- `phone`: required, string, max:20\n- `shipping_address`: required, string, max:500\n- `payment_method`: required, one of: gopay, dana, qris, bca, ovo, shopeepay\n- `total_amount`: required, integer, min:0\n- `order_items`: required, array, min:1 item\n- `order_items.*.souvenir_id`: required, valid UUID, must exist in souvenirs table\n- `order_items.*.quantity`: required, integer, min:1\n- `order_items.*.price`: required, integer, min:0\n\n## Note\nRequires authentication. Response includes Midtrans snap_token for payment."
          }
        },
        {
          "name": "Delete Order (Auth Required)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-XSRF-TOKEN",
                "value": "{{xsrf_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/orders/:order",
              "host": ["{{base_url}}"],
              "path": ["orders", ":order"],
              "variable": [
                {
                  "key": "order",
                  "value": "order-uuid-here",
                  "description": "Order UUID (must be pending status)"
                }
              ]
            }
          }
        }
      ]
    },
